{"0":null,"0-2":{"rawHtml":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n    <title>Status Hub</title>\n    <meta name=\"description\" content=\"Kibana-style status hub for Tangent project workstreams, backlog flow, and delivery metrics.\">\n    <link rel=\"stylesheet\" href=\"../style.css\">\n    <style>\n        #article-view {\n            max-width: none !important;\n            width: 100%;\n            margin: 0;\n        }\n        #article-view .article-frame {\n            width: 100%;\n            max-width: none;\n            margin: 0;\n        }\n        .status-hub {\n            --status-text: #d7d9dc;\n            --status-muted: #a6adb5;\n            width: 100%;\n            max-width: none;\n            margin: 0;\n            margin-bottom: 0;\n            padding: 18px 20px 32px 20px;\n            background: transparent;\n            border: none;\n            box-shadow: none;\n            color: var(--status-text);\n        }\n        .status-hub > .back-link {\n            display: none;\n        }\n        .status-hub h1,\n        .status-hub h2,\n        .status-hub h3,\n        .status-hub p,\n        .status-hub li,\n        .status-hub td,\n        .status-hub strong,\n        .status-hub span {\n            color: var(--status-text);\n        }\n        .status-hero {\n            margin: 0 0 14px 0;\n            padding: 16px 18px;\n            border: 1px solid var(--border);\n            border-radius: 12px;\n            background: var(--bg-secondary);\n        }\n        .status-hero-title {\n            display: flex;\n            align-items: baseline;\n            justify-content: space-between;\n            gap: 12px;\n            margin-bottom: 8px;\n        }\n        .status-hero-title h1 {\n            margin: 0;\n            font-size: clamp(1.3rem, 1.8vw, 2.1rem);\n        }\n        .status-hero-label {\n            font-size: 0.72rem;\n            text-transform: uppercase;\n            letter-spacing: 0.08em;\n            opacity: 1;\n            color: var(--status-muted);\n        }\n        .status-hero p {\n            margin: 0;\n            opacity: 1;\n            color: var(--status-muted);\n        }\n        .status-kpis {\n            display: grid;\n            grid-template-columns: repeat(6, minmax(0, 1fr));\n            gap: 12px;\n            margin: 0 0 14px 0;\n        }\n        .status-kpi {\n            border: 1px solid var(--border);\n            border-radius: 12px;\n            padding: 12px;\n            background: var(--bg-secondary);\n            min-height: 94px;\n        }\n        .status-kpi-top {\n            display: flex;\n            justify-content: space-between;\n            align-items: baseline;\n            gap: 8px;\n            margin-bottom: 6px;\n        }\n        .status-kpi-trend {\n            font-size: 0.72rem;\n            opacity: 1;\n            color: var(--status-muted);\n        }\n        .status-kpi-value {\n            display: block;\n            font-size: clamp(1.2rem, 2vw, 1.8rem);\n            line-height: 1.1;\n            font-weight: 700;\n        }\n        .status-kpi-label {\n            font-size: 0.72rem;\n            opacity: 1;\n            text-transform: uppercase;\n            letter-spacing: 0.08em;\n            color: var(--status-muted);\n        }\n        .status-kpi-bar {\n            display: none;\n        }\n        .status-kpi-bar > span {\n            display: block;\n            height: 100%;\n            background: var(--accent);\n        }\n        .status-dashboard {\n            display: grid;\n            grid-template-columns: 2fr 1.25fr 1.25fr;\n            gap: 12px;\n            align-items: start;\n        }\n        .status-stack {\n            display: grid;\n            gap: 12px;\n            align-content: start;\n            grid-auto-rows: max-content;\n        }\n        .status-section {\n            border: 1px solid var(--border);\n            border-radius: 12px;\n            padding: 12px;\n            background: var(--bg-secondary);\n        }\n        .status-section h3 {\n            margin: 0;\n            font-size: 0.94rem;\n            letter-spacing: 0.04em;\n            text-transform: uppercase;\n            opacity: 1;\n            color: var(--status-text);\n        }\n        .status-section-head {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            gap: 8px;\n            margin-bottom: 10px;\n            border-bottom: 1px solid var(--border);\n            padding-bottom: 8px;\n        }\n        .status-pill {\n            font-size: 0.68rem;\n            text-transform: uppercase;\n            letter-spacing: 0.08em;\n            border: 1px solid var(--border);\n            border-radius: 999px;\n            padding: 2px 7px;\n            opacity: 1;\n            color: var(--status-muted);\n        }\n        .status-grid-two {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 10px;\n            align-items: start;\n        }\n        .status-items {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n            display: grid;\n            gap: 7px;\n        }\n        .status-item {\n            display: flex;\n            gap: 8px;\n            align-items: flex-start;\n            padding: 9px 10px;\n            border-radius: 8px;\n            border: 1px solid var(--border);\n            background: var(--bg-primary);\n        }\n        .status-dot {\n            width: 8px;\n            height: 8px;\n            margin-top: 6px;\n            border-radius: 50%;\n            flex: 0 0 8px;\n            background: var(--accent);\n        }\n        .status-dot.warn { background: #e2a33d; }\n        .status-dot.pause { background: #b06bff; }\n        .status-dot.done { background: #36cc8f; }\n        .status-item p {\n            margin: 0;\n            font-size: 0.9rem;\n        }\n        .status-item-meta {\n            display: block;\n            font-size: 0.74rem;\n            opacity: 1;\n            margin-top: 2px;\n            color: var(--status-muted);\n        }\n        .status-item-meta-link {\n            color: var(--status-muted);\n            text-decoration: underline;\n            text-underline-offset: 2px;\n        }\n        .status-item-meta-link:hover {\n            color: var(--status-text);\n        }\n        .status-mini-metrics {\n            display: grid;\n            grid-template-columns: repeat(3, minmax(0, 1fr));\n            gap: 8px;\n        }\n        .status-mini {\n            border: 1px solid var(--border);\n            border-radius: 8px;\n            padding: 8px;\n            background: var(--bg-primary);\n        }\n        .status-mini strong {\n            display: block;\n            font-size: 1rem;\n            line-height: 1.1;\n        }\n        .status-mini span {\n            font-size: 0.68rem;\n            text-transform: uppercase;\n            opacity: 1;\n            letter-spacing: 0.06em;\n            color: var(--status-muted);\n        }\n        .status-table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 0.84rem;\n        }\n        .status-table th,\n        .status-table td {\n            text-align: left;\n            padding: 7px 6px;\n            border-bottom: 1px solid var(--border);\n        }\n        .status-table th {\n            font-size: 0.68rem;\n            text-transform: uppercase;\n            letter-spacing: 0.07em;\n            opacity: 1;\n            color: var(--status-muted);\n        }\n        .status-spark {\n            --velocity-gap: 3px;\n            display: grid;\n            grid-template-columns: repeat(12, minmax(0, 1fr));\n            align-items: end;\n            gap: var(--velocity-gap);\n            min-height: 72px;\n            padding: 6px 0 2px 0;\n        }\n        .status-spark-item {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: flex-end;\n            gap: 4px;\n        }\n        .status-spark-count {\n            font-size: 0.62rem;\n            color: var(--status-muted);\n            line-height: 1;\n            text-align: center;\n            min-height: 10px;\n        }\n        .status-spark-bar {\n            width: 100%;\n            border-radius: 4px 4px 2px 2px;\n            background: rgba(0,255,65,0.4);\n        }\n        .status-spark-bar.active {\n            background: var(--accent);\n        }\n        .status-spark-markers {\n            display: grid;\n            grid-template-columns: repeat(12, minmax(0, 1fr));\n            gap: var(--velocity-gap);\n            margin-top: 6px;\n            font-size: 0.62rem;\n            color: var(--status-muted);\n            text-align: center;\n        }\n        .status-spark-markers span {\n            opacity: 0.9;\n            white-space: nowrap;\n        }\n        .status-note {\n            font-size: 0.78rem;\n            opacity: 1;\n            margin-top: 8px;\n            color: var(--status-muted);\n        }\n        [data-theme=\"light\"] .status-kpi-bar > span {\n            background: rgba(80,80,80,0.65);\n        }\n        [data-theme=\"light\"] .status-hub {\n            --status-text: #2d3136;\n            --status-muted: #4f5862;\n        }\n        @media (max-width: 1380px) {\n            .status-dashboard {\n                grid-template-columns: 1.6fr 1fr;\n            }\n            .status-stack:nth-child(3) {\n                grid-column: 1 / -1;\n            }\n        }\n        @media (max-width: 1080px) {\n            .status-hub {\n                width: 100%;\n            }\n            .status-kpis {\n                grid-template-columns: repeat(3, minmax(0, 1fr));\n            }\n            .status-dashboard {\n                grid-template-columns: 1fr;\n            }\n        }\n        @media (max-width: 760px) {\n            .status-kpis {\n                grid-template-columns: repeat(2, minmax(0, 1fr));\n            }\n            .status-grid-two,\n            .status-mini-metrics {\n                grid-template-columns: 1fr;\n            }\n        }\n        @media (max-width: 520px) {\n            .status-hub {\n                width: 100%;\n                margin-top: 0;\n                padding: 10px 20px 32px 20px;\n            }\n            .status-kpis {\n                grid-template-columns: 1fr;\n            }\n            .status-kpi {\n                min-height: 80px;\n            }\n            .status-hero {\n                padding: 12px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"binary-bg\" aria-hidden=\"true\"></div>\n\n    <main class=\"article-container status-hub\" data-gh-owner=\"codingatmyjob\" data-gh-repo=\"codingatmyjob.github.io\" data-gh-production-workflow=\"deploy-production.yml\">\n        <section class=\"status-hero\">\n            <div class=\"status-hero-title\">\n                <h1>Status Hub</h1>\n                <span class=\"status-hero-label\">Live Project Telemetry</span>\n            </div>\n            <p>\n                Kibana style board for tracking commit activity, delivery health, and development trends throughout the repository.\n                Monitor throughput, and keep ideas, orphaned items, and on hold issues visible in a single compact dashboard.\n            </p>\n        </section>\n\n        <section class=\"status-kpis\" aria-label=\"status summary\">\n            <div class=\"status-kpi\">\n                <div class=\"status-kpi-top\">\n                    <span class=\"status-kpi-value\" data-gh-stat=\"stars\">0</span>\n                    <span class=\"status-kpi-trend\">GitHub signal</span>\n                </div>\n                <span class=\"status-kpi-label\">Repo Stars</span>\n                <div class=\"status-kpi-bar\"><span style=\"width: 45%\"></span></div>\n            </div>\n            <div class=\"status-kpi\">\n                <div class=\"status-kpi-top\">\n                    <span class=\"status-kpi-value\" data-gh-stat=\"forks\">0</span>\n                    <span class=\"status-kpi-trend\">Community reuse</span>\n                </div>\n                <span class=\"status-kpi-label\">Repo Forks</span>\n                <div class=\"status-kpi-bar\"><span style=\"width: 35%\"></span></div>\n            </div>\n            <div class=\"status-kpi\">\n                <div class=\"status-kpi-top\">\n                    <span class=\"status-kpi-value\" data-gh-stat=\"openIssues\">0</span>\n                    <span class=\"status-kpi-trend\">Workload surface</span>\n                </div>\n                <span class=\"status-kpi-label\">Open Issues</span>\n                <div class=\"status-kpi-bar\"><span style=\"width: 55%\"></span></div>\n            </div>\n            <div class=\"status-kpi\">\n                <div class=\"status-kpi-top\">\n                    <span class=\"status-kpi-value\" data-gh-stat=\"watchers\">0</span>\n                    <span class=\"status-kpi-trend\">Active subscribers</span>\n                </div>\n                <span class=\"status-kpi-label\">Repo Watchers</span>\n                <div class=\"status-kpi-bar\"><span style=\"width: 42%\"></span></div>\n            </div>\n            <div class=\"status-kpi\">\n                <div class=\"status-kpi-top\">\n                    <span class=\"status-kpi-value\" data-gh-stat=\"productionCommits\">0</span>\n                    <span class=\"status-kpi-trend\" data-gh-stat=\"productionTrend\">0 vs prev 30d</span>\n                </div>\n                <span class=\"status-kpi-label\">Production Commits (30d)</span>\n                <div class=\"status-kpi-bar\"><span style=\"width: 93%\"></span></div>\n            </div>\n            <div class=\"status-kpi\">\n                <div class=\"status-kpi-top\">\n                    <span class=\"status-kpi-value\" data-gh-stat=\"commitVelocity\">0/wk</span>\n                    <span class=\"status-kpi-trend\" data-gh-stat=\"velocityTrend\">Weekly commits</span>\n                </div>\n                <span class=\"status-kpi-label\">Delivery Velocity</span>\n                <div class=\"status-kpi-bar\"><span style=\"width: 57%\"></span></div>\n            </div>\n        </section>\n\n        <section class=\"status-dashboard\">\n            <div class=\"status-stack\">\n                <section class=\"status-section\" aria-labelledby=\"ideas-heading\">\n                    <div class=\"status-section-head\">\n                        <h3 id=\"ideas-heading\">Ideas and Orphans</h3>\n                        <span class=\"status-pill\">Label Driven</span>\n                    </div>\n                    <div class=\"status-grid-two\">\n                        <ul class=\"status-items\" data-gh-feed-ideas>\n                            <li class=\"status-item\">\n                                <span class=\"status-dot\" aria-hidden=\"true\"></span>\n                                <p>\n                                    Loading ideas...\n                                    <span class=\"status-item-meta\">Label: idea</span>\n                                </p>\n                            </li>\n                        </ul>\n                        <ul class=\"status-items\" data-gh-feed-orphans>\n                            <li class=\"status-item\">\n                                <span class=\"status-dot warn\" aria-hidden=\"true\"></span>\n                                <p>\n                                    Loading orphans...\n                                    <span class=\"status-item-meta\">Label: orphan</span>\n                                </p>\n                            </li>\n                        </ul>\n                    </div>\n                </section>\n\n                <section class=\"status-section\" aria-labelledby=\"flow-heading\">\n                    <div class=\"status-section-head\">\n                        <h3 id=\"flow-heading\">Recent Commit Activity</h3>\n                        <span class=\"status-pill\">Live Feed</span>\n                    </div>\n                    <ul class=\"status-items\" data-gh-feed-commits>\n                        <li class=\"status-item\">\n                            <span class=\"status-dot\" aria-hidden=\"true\"></span>\n                            <p>\n                                Loading commit feed...\n                                <span class=\"status-item-meta\">Fetching recent repository activity.</span>\n                            </p>\n                        </li>\n                    </ul>\n                </section>\n            </div>\n\n            <div class=\"status-stack\">\n                <section class=\"status-section\" aria-labelledby=\"velocity-heading\">\n                    <div class=\"status-section-head\">\n                        <h3 id=\"velocity-heading\">Velocity</h3>\n                        <span class=\"status-pill\">12 Weeks</span>\n                    </div>\n                    <div class=\"status-spark\" data-gh-weekly-bars aria-label=\"12-week commit velocity\">\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 10px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 14px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 12px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 18px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 16px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 20px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 26px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 22px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 28px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 24px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar\" style=\"height: 30px\"></span></div>\n                        <div class=\"status-spark-item\"><span class=\"status-spark-count\">0</span><span class=\"status-spark-bar active\" style=\"height: 34px\"></span></div>\n                    </div>\n                    <div class=\"status-spark-markers\" data-gh-week-labels aria-hidden=\"true\">\n                        <span>-11w</span>\n                        <span>-10w</span>\n                        <span>-9w</span>\n                        <span>-8w</span>\n                        <span>-7w</span>\n                        <span>-6w</span>\n                        <span>-5w</span>\n                        <span>-4w</span>\n                        <span>-3w</span>\n                        <span>-2w</span>\n                        <span>-1w</span>\n                        <span>now</span>\n                    </div>\n                    <p class=\"status-note\" data-gh-stat=\"velocitySummary\">12-week total commit activity.</p>\n                </section>\n\n                <section class=\"status-section\" aria-labelledby=\"operational-heading\">\n                    <div class=\"status-section-head\">\n                        <h3 id=\"operational-heading\">Operational Metrics</h3>\n                        <span class=\"status-pill\">Health</span>\n                    </div>\n                    <div class=\"status-mini-metrics\">\n                        <div class=\"status-mini\"><strong data-gh-stat=\"buildPassRate30d\">--%</strong><span>Build Pass Rate (30d)</span></div>\n                        <div class=\"status-mini\"><strong data-gh-stat=\"deploysMonth\">--</strong><span>Deploys / Month</span></div>\n                        <div class=\"status-mini\"><strong data-gh-stat=\"prMergeLag\">--</strong><span>PR Merge Lag</span></div>\n                        <div class=\"status-mini\"><strong data-gh-stat=\"orphansOpen\">--</strong><span>Orphans Open</span></div>\n                        <div class=\"status-mini\"><strong data-gh-stat=\"ideasOpen\">--</strong><span>Ideas Open</span></div>\n                        <div class=\"status-mini\"><strong data-gh-stat=\"onHoldCount\">--</strong><span>On Hold</span></div>\n                    </div>\n                </section>\n\n                <section class=\"status-section\" aria-labelledby=\"hold-heading\">\n                    <div class=\"status-section-head\">\n                        <h3 id=\"hold-heading\">On Hold</h3>\n                        <span class=\"status-pill\">Label Driven</span>\n                    </div>\n                    <ul class=\"status-items\" data-gh-feed-blocked>\n                        <li class=\"status-item\">\n                            <span class=\"status-dot pause\" aria-hidden=\"true\"></span>\n                            <p>\n                                Loading blocked/on-hold issues...\n                                <span class=\"status-item-meta\">Labels: blocked, on-hold, on hold, needs-decision</span>\n                            </p>\n                        </li>\n                    </ul>\n                    <p class=\"status-note\">Pinned On Hold Projects</p>\n                    <ul class=\"status-items\" data-manual-on-hold>\n                        <li class=\"status-item\">\n                            <span class=\"status-dot pause\" aria-hidden=\"true\"></span>\n                            <p>\n                                NOAA Tides LLM Chatbot Demo\n                                <span class=\"status-item-meta\">Manual on-hold entry</span>\n                            </p>\n                        </li>\n                        <li class=\"status-item\">\n                            <span class=\"status-dot pause\" aria-hidden=\"true\"></span>\n                            <p>\n                                Efficient HTML Maps with PyDeck\n                                <span class=\"status-item-meta\">Manual on-hold entry</span>\n                            </p>\n                        </li>\n                    </ul>\n                </section>\n            </div>\n\n            <div class=\"status-stack\">\n                <section class=\"status-section\" aria-labelledby=\"completed-heading\">\n                    <div class=\"status-section-head\">\n                        <h3 id=\"completed-heading\">Recently Completed</h3>\n                        <span class=\"status-pill\">Shipped</span>\n                    </div>\n                    <ul class=\"status-items\">\n                        <li class=\"status-item\">\n                            <span class=\"status-dot done\" aria-hidden=\"true\"></span>\n                            <p>\n                                Status Hub launched and linked in sidebar.\n                                <span class=\"status-item-meta\">Type: UI addition</span>\n                            </p>\n                        </li>\n                        <li class=\"status-item\">\n                            <span class=\"status-dot done\" aria-hidden=\"true\"></span>\n                            <p>\n                                Related-articles generation integrated into build.\n                                <span class=\"status-item-meta\">Type: data pipeline</span>\n                            </p>\n                        </li>\n                        <li class=\"status-item\">\n                            <span class=\"status-dot done\" aria-hidden=\"true\"></span>\n                            <p>\n                                Converted legacy hash-routed SPA shell to Vite React SSG route generation.\n                                <span class=\"status-item-meta\">Type: architecture migration</span>\n                            </p>\n                        </li>\n                        <li class=\"status-item\">\n                            <span class=\"status-dot done\" aria-hidden=\"true\"></span>\n                            <p>\n                                Feature-based image folder normalization.\n                                <span class=\"status-item-meta\">Type: refactor</span>\n                            </p>\n                        </li>\n                    </ul>\n                </section>\n\n                <section class=\"status-section\" aria-labelledby=\"mix-heading\">\n                    <div class=\"status-section-head\">\n                        <h3 id=\"mix-heading\">Deployment Activity</h3>\n                        <span class=\"status-pill\">Production Workflow</span>\n                    </div>\n                    <ul class=\"status-items\" data-gh-feed-deployments>\n                        <li class=\"status-item\">\n                            <span class=\"status-dot\" aria-hidden=\"true\"></span>\n                            <p>\n                                Loading deploy-production workflow runs...\n                                <span class=\"status-item-meta\">Recent production deploy history.</span>\n                            </p>\n                        </li>\n                    </ul>\n                </section>\n            </div>\n        </section>\n    </main>\n</body>\n</html>\n"}}