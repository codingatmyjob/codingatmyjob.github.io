{"0":null,"0-1":{"rawHtml":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Real-Time Traffic Object Detection with TensorFlow.js</title>\n  <link rel=\"stylesheet\" href=\"../style.css\" />\n  <style>\n    .traffic-detector-article {\n      max-width: 1200px;\n    }\n\n    .traffic-detector-shell {\n      display: flex;\n      flex-direction: column;\n      gap: 18px;\n      margin-top: 18px;\n    }\n\n    .traffic-card {\n      margin: 0;\n      padding: 18px;\n      background: rgba(128, 128, 128, 0.12);\n      border: 1px solid var(--border);\n      border-radius: 10px;\n    }\n\n    .article-container .traffic-card > h2 {\n      margin: 0 0 10px 0 !important;\n    }\n\n    [data-theme=\"light\"] .traffic-card {\n      background: rgba(0, 0, 0, 0.05);\n    }\n\n    .traffic-stats {\n      display: grid;\n      grid-template-columns: repeat(4, minmax(0, 1fr));\n      gap: 10px;\n      margin: 10px 0 12px;\n    }\n\n    .traffic-stat {\n      border: 1px solid var(--border);\n      border-radius: 8px;\n      padding: 9px 10px;\n      background: rgba(0, 0, 0, 0.14);\n    }\n\n    .traffic-stat-label {\n      display: block;\n      font-size: 11px;\n      color: rgba(255, 255, 255, 0.72);\n      text-transform: uppercase;\n      letter-spacing: 0.06em;\n      margin-bottom: 4px;\n    }\n\n    .traffic-stat-value {\n      display: block;\n      font-size: 14px;\n      color: var(--text-primary);\n      line-height: 1.3;\n      word-break: break-word;\n    }\n\n    .traffic-actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 10px;\n      margin-top: 8px;\n    }\n\n    .traffic-stage {\n      position: relative;\n      border: 1px solid var(--border);\n      border-radius: 12px;\n      overflow: hidden;\n      background: #050705;\n      min-height: 460px;\n    }\n\n    .traffic-stage-fullscreen-btn {\n      position: absolute;\n      top: 8px;\n      right: 8px;\n      z-index: 2;\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      width: 30px;\n      height: 30px;\n      padding: 0;\n      border-radius: 6px;\n      background: rgba(5, 7, 5, 0.66);\n      backdrop-filter: blur(4px);\n    }\n\n    .traffic-stage-fullscreen-btn svg {\n      width: 16px;\n      height: 16px;\n      display: block;\n      pointer-events: none;\n    }\n\n    .traffic-video {\n      width: 100%;\n      height: 100%;\n      display: block;\n      object-fit: contain;\n      background: #050705;\n      min-height: 460px;\n    }\n\n    .traffic-overlay {\n      position: absolute;\n      inset: 0;\n      width: 100%;\n      height: 100%;\n      pointer-events: none;\n    }\n\n    .traffic-panel {\n      border: 1px solid var(--border);\n      border-radius: 12px;\n      padding: 14px;\n      background: rgba(0, 0, 0, 0.18);\n      align-self: stretch;\n      width: 100%;\n      box-sizing: border-box;\n    }\n\n    .traffic-panel h2 {\n      font-size: 1.05rem;\n      margin: 0 0 14px 0 !important;\n      text-align: left;\n    }\n\n    .traffic-panel h3 {\n      font-size: 0.95rem;\n      margin: 14px 0 10px 0 !important;\n      text-align: left;\n      color: rgba(255, 255, 255, 0.9);\n      letter-spacing: 0.02em;\n    }\n\n    .traffic-hidden {\n      display: none !important;\n    }\n\n    .traffic-panel dl {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 10px 14px;\n      margin: 0;\n      width: 100%;\n    }\n\n    .traffic-panel dl > div {\n      min-width: 0;\n    }\n\n    .traffic-panel dt {\n      font-size: 12px;\n      color: rgba(255, 255, 255, 0.72);\n      text-transform: uppercase;\n      letter-spacing: 0.06em;\n    }\n\n    .traffic-panel dd {\n      margin: 3px 0 0 0;\n      font-size: 14px;\n      color: var(--text-primary);\n      line-height: 1.4;\n      word-break: break-word;\n    }\n\n    .traffic-toggle {\n      width: auto;\n      border: 1px solid var(--border);\n      background: var(--bg-secondary);\n      color: var(--text-primary);\n      border-radius: 8px;\n      padding: 9px 14px;\n      font-family: inherit;\n      font-size: 0.9rem;\n      cursor: pointer;\n      transition: transform 0.15s, filter 0.15s, background 0.2s;\n    }\n\n    .traffic-toggle:hover:not(:disabled) {\n      transform: translateY(-1px);\n      background: var(--border);\n    }\n\n    .traffic-toggle:disabled {\n      opacity: 0.5;\n      cursor: not-allowed;\n    }\n\n    .traffic-toggle-primary {\n      background: var(--accent);\n      color: var(--bg-primary);\n      border-color: var(--accent);\n      font-weight: 700;\n    }\n\n    .traffic-toggle-primary:hover:not(:disabled) {\n      filter: brightness(1.08);\n      background: var(--accent);\n    }\n\n    .traffic-note {\n      margin: 8px 0 0 0;\n      font-size: 0.82rem;\n      min-height: 1.2em;\n      opacity: 0.75;\n    }\n\n    [data-theme=\"light\"] .traffic-stage {\n      background: #d4d7db;\n    }\n\n    [data-theme=\"light\"] .traffic-video {\n      background: #d4d7db;\n    }\n\n    .traffic-stage:fullscreen,\n    .traffic-stage:-webkit-full-screen {\n      width: 100vw;\n      height: 100vh;\n      max-width: none;\n      border-radius: 0;\n      border: none;\n      background: #000;\n    }\n\n    .traffic-stage:fullscreen .traffic-video,\n    .traffic-stage:-webkit-full-screen .traffic-video {\n      min-height: 100vh;\n      height: 100vh;\n      background: #000;\n    }\n\n    [data-theme=\"light\"] .traffic-panel {\n      background: rgba(0, 0, 0, 0.03);\n    }\n\n    [data-theme=\"light\"] .traffic-panel dt {\n      color: rgba(54, 54, 54, 0.72);\n    }\n\n    [data-theme=\"light\"] .traffic-stat {\n      background: rgba(255, 255, 255, 0.38);\n    }\n\n    [data-theme=\"light\"] .traffic-stat-label {\n      color: rgba(54, 54, 54, 0.72);\n    }\n\n    [data-theme=\"light\"] .traffic-panel h3 {\n      color: rgba(22, 22, 22, 0.86);\n    }\n\n    [data-theme=\"light\"] .traffic-note {\n      color: rgba(54, 54, 54, 0.72);\n    }\n\n    @media (max-width: 980px) {\n      .traffic-stage,\n      .traffic-video {\n        min-height: 260px;\n      }\n\n      .traffic-stats {\n        grid-template-columns: repeat(2, minmax(0, 1fr));\n      }\n    }\n\n    @media (max-width: 700px) {\n      .traffic-stats {\n        grid-template-columns: 1fr;\n      }\n\n      .traffic-panel dl {\n        grid-template-columns: 1fr;\n      }\n    }\n  </style>\n</head>\n<body>\n  <main class=\"article-container traffic-detector-article\">\n    <h1>Real-Time Traffic Object Detection with TensorFlow.js</h1>\n    <div class=\"meta\">\n      <time datetime=\"2026-06-26\">June 26, 2026</time>\n    </div>\n    <div class=\"tags\">\n      <span class=\"tag\">Project</span>\n      <span class=\"tag\">JavaScript</span>\n      <span class=\"tag\">TensorFlow.js</span>\n      <span class=\"tag\">Library</span>\n    </div>\n\n    <article>\n      <h2>Overview</h2>\n      <p>\n        I recently decided I was going to give myself 10 days to study for and pass AI-900 before it gets retired June 30, 2026. \n        I reached the computer vision section of study and thought it would be fun to try and build something lightweight in the browser.\n        There are hundreds of different methods for models and object detection, but I wanted to make something that I could display <i>here</i>.\n      </p>\n      <p>\n        Going into this I had absolutely zero experience with object detection but I had 2 main goals: \n        <ol>\n          <li>Use a live traffic feed as my data source (don't care where from)</li>\n          <li>Run entirely client-side</li>\n        </ol>\n      </p>\n\n      <h2>Live Feed</h2>\n      <p>\n        Below is a TensorFlow.js object detection demonstration that runs fully in the browser. The HLS.js library enables \n        a live HTTPS stream sourced from the Iowa Department of Transportation. That stream is then fed into the TensorFlow.js COCO-SSD \n        (Common Objects in Context Single Shot MultiBox Detection) model, which runs lightweight object detection directly in the browser. \n      </p>\n      <p>Click the \"Load Live Feed\" button to load required libraries and start viewing the live feed with object detection.</p>\n\n      <div class=\"traffic-detector-shell\" aria-label=\"Traffic object detection demo\">\n        <section class=\"traffic-card\" aria-label=\"Traffic runtime card\">\n          <h2>Status</h2>\n          <div class=\"traffic-stats\" aria-label=\"Runtime quick stats\">\n            <div class=\"traffic-stat\">\n              <span class=\"traffic-stat-label\">Model</span>\n              <span id=\"quick-model\" class=\"traffic-stat-value\">Not loaded</span>\n            </div>\n            <div class=\"traffic-stat\">\n              <span class=\"traffic-stat-label\">Backend</span>\n              <span id=\"quick-backend\" class=\"traffic-stat-value\">Pending</span>\n            </div>\n            <div class=\"traffic-stat\">\n              <span class=\"traffic-stat-label\">Stream</span>\n              <span id=\"quick-stream\" class=\"traffic-stat-value\">Not connected</span>\n            </div>\n            <div class=\"traffic-stat\">\n              <span class=\"traffic-stat-label\">Inference FPS</span>\n              <span id=\"quick-fps\" class=\"traffic-stat-value\">0</span>\n            </div>\n          </div>\n          <div id=\"traffic-actions\" class=\"traffic-actions\">\n            <button id=\"load-traffic-btn\" class=\"traffic-toggle traffic-toggle-primary\" type=\"button\">Load Live Feed</button>\n          </div>\n\n          <div id=\"traffic-stage-wrap\" class=\"traffic-hidden\">\n            <div id=\"traffic-stage\" class=\"traffic-stage\">\n              <video id=\"traffic-video\" class=\"traffic-video\" controls controlslist=\"nofullscreen\" disablepictureinpicture autoplay muted playsinline preload=\"metadata\" crossorigin=\"anonymous\"></video>\n              <canvas id=\"traffic-overlay\" class=\"traffic-overlay\" aria-hidden=\"true\"></canvas>\n              <button id=\"traffic-fullscreen-btn\" class=\"traffic-toggle traffic-stage-fullscreen-btn\" type=\"button\" aria-label=\"Fullscreen feed\" title=\"Fullscreen feed\">\n                <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\">\n                  <path fill=\"currentColor\" d=\"M4 9V4h5v2H6v3H4zm10-5h6v6h-2V6h-4V4zM4 15h2v3h3v2H4v-5zm14 3v-3h2v5h-5v-2h3z\" />\n                </svg>\n              </button>\n            </div>\n          </div>\n        </section>\n      </div>\n\n      <h2>Challenges</h2>\n      <p>\n        Unlike past projects I think I did a better job of staying within the original scope! A lot of research went into actually finding an open feed \n        that didn't require an API or some kind of proxy service to get around CORS. On top of that, these lightweight object detection models are very \n        input sensitive (they require a high quality video, at a similar angle to what they were trained on). \n      </p>\n      <p>\n        This meant even though I had multiple feeds that fit my criteria, I also need a camera angle that enabled the model to work properly. I ended up \n        finding a feed from the Iowa DOT that sits directly over an intersection with a red light, pointed straight down onto the oncoming traffic below. \n        This ended up being the best camera I could find that met the criteria. \n      </p>\n      <p>\n        I found myself compromising on the model choice as well. I had 3 options available: \n        <ul>\n          <li>lite_mobilenet_v2 - fastest but least accurate model</li>\n          <li>mobilenet_v1 - middle ground model where we sacrifice some accuracy for a noticeable boost in speed</li>\n          <li>mobilenet_v2 - the most accurate but also the slowest model</li>\n        </ul>\n      </p>\n      <p>\n        Even though mobilenet_v1 is the oldest of the models, it ended up being the best model for our use case. I saw a noticeable boost in accuracy over the \n        lite version, and the mobilenet_v2 model was just too slow to be usable in a live feed scenario without a dedicated processor.\n      </p>\n      <p>\n        I also had to include an inference fallback based on device hardware; WebGL -&gt; WASM -&gt; CPU. WebGL is picked with the highest priority when a device has a GPU/hardware acceleration enabled,\n        WASM is the fallback for browsers where WebGL is unavailable, and CPU last so the demo still runs even in constrained environments.\n      </p>\n      <p>\n        Finally, I had difficulty accounting for fullscreen. If a user tried to use the native fullscreen button, the object detection didn't follow. \n        I had to make sure the fullscreen functionality applied to the video <i>and</i> canvas elements, and not just the video like the native button did.\n      </p>\n      <h2>Final Thoughts</h2>\n      <p>\n        With a heavier model, or an actual backend to process inference/video input, I could get this working with much higher speed and accuracy. But, constraints are constraints and I \n        didn't want scope creep to take over the project.\n      </p>\n    </article>\n  </main>\n\n  <script>\n    {\n    function loadScript(src) {\n      return new Promise((resolve, reject) => {\n        const existing = document.querySelector(`script[data-lib-src=\"${src}\"]`)\n        if (existing) {\n          existing.addEventListener('load', () => resolve(), { once: true })\n          existing.addEventListener('error', () => reject(new Error(`Failed to load ${src}`)), { once: true })\n          // If it is already loaded, resolve immediately.\n          if (existing.dataset.loaded === 'true') resolve()\n          return\n        }\n\n        const script = document.createElement('script')\n        script.src = src\n        script.async = true\n        script.dataset.libSrc = src\n        script.addEventListener('load', () => {\n          script.dataset.loaded = 'true'\n          resolve()\n        }, { once: true })\n        script.addEventListener('error', () => reject(new Error(`Failed to load ${src}`)), { once: true })\n        document.head.appendChild(script)\n      })\n    }\n\n    async function ensureLibraries() {\n      await loadScript('https://cdn.jsdelivr.net/npm/hls.js@1.6.12/dist/hls.min.js')\n      await loadScript('https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4.22.0/dist/tf.min.js')\n      await loadScript('https://cdn.jsdelivr.net/npm/@tensorflow/tfjs-backend-wasm@4.22.0/dist/tf-backend-wasm.min.js')\n      await loadScript('https://cdn.jsdelivr.net/npm/@tensorflow-models/coco-ssd@2.2.3/dist/coco-ssd.min.js')\n    }\n\n    // Iowa DOT CCTV: Cedar Rapids feed — https, CORS *, no auth\n    const TRAFFIC_HLS_URL = 'https://video3.iowadot.gov:8888/cedarrapids/dqtv19lb/playlist.m3u8'\n    const DETECTION_CLASS_ALLOWLIST = new Set(['car', 'truck', 'motorcycle'])\n    const DETECTION_MODEL_BASE = 'mobilenet_v1'\n    const DEFAULT_BACKEND_PREFERENCE = 'auto'\n    const IS_MOBILE_DEVICE = /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent)\n    const USE_CLASS_ALLOWLIST = true\n    const DETECTION_SCORE_THRESHOLD = 0.40\n    const DETECTION_INTERVAL_MS = IS_MOBILE_DEVICE ? 300 : 200\n    const DETECTION_MAX_PREDICTIONS = 30\n    const DETECTION_INPUT_MAX_WIDTH = IS_MOBILE_DEVICE ? 480 : 640\n    const MAX_DISPLAYED_DETECTIONS = 20\n    const MAX_CAR_AREA_RATIO = 0.08\n\n    const BOX_COLORS = {\n      car: '#ffee00',\n      truck: '#ff8c00',\n      motorcycle: '#00c2ff'\n    }\n\n    const videoEl = document.getElementById('traffic-video')\n    const canvasEl = document.getElementById('traffic-overlay')\n\n    const loadProjectBtn = document.getElementById('load-traffic-btn')\n    const actionsEl = document.getElementById('traffic-actions')\n    const stageEl = document.getElementById('traffic-stage')\n    const stageWrapEl = document.getElementById('traffic-stage-wrap')\n    const fullscreenBtnEl = document.getElementById('traffic-fullscreen-btn')\n    const quickModelEl = document.getElementById('quick-model')\n    const quickStreamEl = document.getElementById('quick-stream')\n    const quickBackendEl = document.getElementById('quick-backend')\n    const quickFpsEl = document.getElementById('quick-fps')\n\n    const detectionCanvas = document.createElement('canvas')\n    const detectionCtx = detectionCanvas.getContext('2d', { willReadFrequently: true })\n\n    const modelCache = window.__trafficDemoModelCache || (window.__trafficDemoModelCache = { promise: null, base: '' })\n    let HlsLib = null\n    let tfLib = null\n    let cocoSsdLib = null\n\n    let hls = null\n    let model = null\n    let rafId = 0\n    let busy = false\n    let videoReady = false\n    let lastInferenceMs = 0\n    let lastFrameMs = performance.now()\n    let lastDetections = []\n    let projectInitializing = false\n    let projectReady = false\n    let currentStreamStatus = 'Not connected'\n    let cleanupComplete = false\n\n    function setModelStatus(value) {\n      if (quickModelEl) quickModelEl.textContent = value\n    }\n\n    function setStreamStatus(value) {\n      currentStreamStatus = value\n      if (quickStreamEl) quickStreamEl.textContent = value\n    }\n\n    function setBackendStatus(value) {\n      if (quickBackendEl) quickBackendEl.textContent = value\n    }\n\n    function setFpsStatus(value) {\n      if (quickFpsEl) quickFpsEl.textContent = value\n    }\n\n    function revealStage() {\n      if (stageWrapEl) {\n        stageWrapEl.classList.remove('traffic-hidden')\n      }\n    }\n\n    async function toggleStageFullscreen() {\n      if (!stageEl) return\n\n      if (document.fullscreenElement === stageEl) {\n        await document.exitFullscreen?.()\n        return\n      }\n\n      if (stageEl.requestFullscreen) {\n        await stageEl.requestFullscreen().catch(() => {})\n      }\n    }\n\n    function updateFullscreenButtonLabel() {\n      if (!fullscreenBtnEl) return\n      const isFullscreen = document.fullscreenElement === stageEl\n      const label = isFullscreen ? 'Exit fullscreen' : 'Fullscreen feed'\n      fullscreenBtnEl.setAttribute('aria-label', label)\n      fullscreenBtnEl.setAttribute('title', label)\n    }\n\n    function clearOverlay() {\n      const ctx = canvasEl.getContext('2d')\n      if (!ctx) return\n      ctx.clearRect(0, 0, canvasEl.width, canvasEl.height)\n    }\n\n    function cleanupTrafficProject() {\n      if (cleanupComplete) return\n      cleanupComplete = true\n\n      cancelAnimationFrame(rafId)\n      rafId = 0\n      busy = false\n      videoReady = false\n      lastInferenceMs = 0\n      lastDetections = []\n\n      if (hls) {\n        hls.destroy()\n        hls = null\n      }\n\n      if (videoEl) {\n        videoEl.pause()\n        videoEl.removeAttribute('src')\n        videoEl.load()\n      }\n\n      if (model && typeof model.dispose === 'function') {\n        model.dispose()\n      }\n\n      model = null\n      modelCache.promise = null\n      modelCache.base = ''\n      clearOverlay()\n    }\n\n    function resolveBackendOrder(preference) {\n      if (preference === 'webgl') return ['webgl', 'wasm', 'cpu']\n      if (preference === 'wasm') return ['wasm', 'cpu', 'webgl']\n      if (preference === 'cpu') return ['cpu', 'wasm', 'webgl']\n      return ['webgl', 'wasm', 'cpu']\n    }\n\n    async function setPreferredBackend() {\n      const backendOrder = resolveBackendOrder(DEFAULT_BACKEND_PREFERENCE)\n\n      if (tfLib.wasm && typeof tfLib.wasm.setWasmPaths === 'function') {\n        tfLib.wasm.setWasmPaths('https://cdn.jsdelivr.net/npm/@tensorflow/tfjs-backend-wasm@4.22.0/dist/')\n      }\n\n      for (const backendName of backendOrder) {\n        const backendReady = await tfLib.setBackend(backendName).catch(() => false)\n        if (backendReady) {\n          await tfLib.ready()\n          return backendName\n        }\n      }\n\n      throw new Error('No supported TensorFlow inference engine found')\n    }\n\n    function drawDetections(detections, width, height) {\n      const ctx = canvasEl.getContext('2d')\n      if (!ctx) return\n\n      canvasEl.width = width\n      canvasEl.height = height\n      ctx.clearRect(0, 0, width, height)\n\n      detections.forEach((item) => {\n        const color = BOX_COLORS[item.class] || '#00ff41'\n        const [x, y, w, h] = item.bbox\n        const label = `${item.class} ${Math.round(item.score * 100)}%`\n\n        ctx.lineWidth = 2\n        ctx.strokeStyle = color\n        ctx.fillStyle = 'rgba(0, 0, 0, 0.45)'\n        ctx.strokeRect(x, y, w, h)\n\n        ctx.font = '600 14px \"Courier New\", monospace'\n        const textWidth = ctx.measureText(label).width + 16\n        const labelHeight = 24\n        const labelY = y > labelHeight + 4 ? y - labelHeight : y + 2\n\n        ctx.fillRect(x, labelY, textWidth, labelHeight)\n        ctx.fillStyle = color\n        ctx.fillText(label, x + 8, labelY + 16)\n      })\n    }\n\n    async function setupStream() {\n      if (!TRAFFIC_HLS_URL || TRAFFIC_HLS_URL.includes('example.com')) {\n        setStreamStatus('Set TRAFFIC_HLS_URL to your real .m3u8 stream URL')\n        return\n      }\n\n      if (videoEl.canPlayType('application/vnd.apple.mpegurl')) {\n        videoEl.src = TRAFFIC_HLS_URL\n        setStreamStatus('HLS connected (native playback)')\n        return\n      }\n\n      if (!HlsLib.isSupported()) {\n        setStreamStatus('HLS playback is not supported in this browser')\n        return\n      }\n\n      hls = new HlsLib({\n        enableWorker: true,\n        lowLatencyMode: true,\n        backBufferLength: 30\n      })\n\n      hls.loadSource(TRAFFIC_HLS_URL)\n      hls.attachMedia(videoEl)\n      hls.on(HlsLib.Events.MANIFEST_PARSED, () => {\n        setStreamStatus('HLS connected')\n      })\n      hls.on(HlsLib.Events.ERROR, (_event, data) => {\n        if (data && data.fatal) {\n          setStreamStatus(`Stream error: ${data.type || 'fatal error'}`)\n        }\n      })\n    }\n\n    async function setupModel() {\n      try {\n        const cacheKey = `${DETECTION_MODEL_BASE}:${DEFAULT_BACKEND_PREFERENCE}`\n        if (!modelCache.promise || modelCache.base !== cacheKey) {\n          modelCache.base = cacheKey\n          modelCache.promise = (async () => {\n            const backend = await setPreferredBackend()\n\n            return cocoSsdLib.load({ base: DETECTION_MODEL_BASE })\n              .then((loadedModel) => ({ loadedModel, backend }))\n          })()\n        }\n\n        const { loadedModel, backend } = await modelCache.promise\n        model = loadedModel\n        setModelStatus(`COCO-SSD ${DETECTION_MODEL_BASE}`)\n        setBackendStatus(backend.toUpperCase())\n      } catch (error) {\n        setModelStatus(`Model failed: ${error?.message || 'unknown error'}`)\n        setBackendStatus('Unavailable')\n      }\n    }\n\n    function tick(nowMs) {\n      rafId = requestAnimationFrame(tick)\n\n      if (!videoReady || !model) return\n      if (!videoEl.videoWidth || !videoEl.videoHeight) return\n\n      // Redraw last detections every frame so boxes stay visible between inference runs\n      if (lastDetections.length > 0) {\n        drawDetections(lastDetections, videoEl.videoWidth, videoEl.videoHeight)\n      }\n\n      if (busy) return\n      if (nowMs - lastInferenceMs < DETECTION_INTERVAL_MS) return\n\n      busy = true\n      lastInferenceMs = nowMs\n\n      const sourceWidth = videoEl.videoWidth\n      const sourceHeight = videoEl.videoHeight\n      const scale = sourceWidth > DETECTION_INPUT_MAX_WIDTH ? (DETECTION_INPUT_MAX_WIDTH / sourceWidth) : 1\n      const inputWidth = Math.max(320, Math.round(sourceWidth * scale))\n      const inputHeight = Math.max(180, Math.round(sourceHeight * scale))\n\n      let detectionSource = videoEl\n      if (detectionCtx) {\n        if (detectionCanvas.width !== inputWidth) detectionCanvas.width = inputWidth\n        if (detectionCanvas.height !== inputHeight) detectionCanvas.height = inputHeight\n        detectionCtx.drawImage(videoEl, 0, 0, inputWidth, inputHeight)\n        detectionSource = detectionCanvas\n      }\n\n      model.detect(detectionSource, DETECTION_MAX_PREDICTIONS, DETECTION_SCORE_THRESHOLD).then((predictions) => {\n        const xScale = sourceWidth / inputWidth\n        const yScale = sourceHeight / inputHeight\n        const scaledPredictions = predictions.map((item) => ({\n          ...item,\n          bbox: [\n            item.bbox[0] * xScale,\n            item.bbox[1] * yScale,\n            item.bbox[2] * xScale,\n            item.bbox[3] * yScale\n          ]\n        }))\n\n        const filtered = scaledPredictions\n          .filter((item) => !USE_CLASS_ALLOWLIST || DETECTION_CLASS_ALLOWLIST.has(item.class))\n          .filter((item) => item.score >= DETECTION_SCORE_THRESHOLD)\n          .filter((item) => item.class !== 'car' || ((item.bbox[2] * item.bbox[3]) / (sourceWidth * sourceHeight)) <= MAX_CAR_AREA_RATIO)\n          .sort((a, b) => b.score - a.score)\n          .slice(0, MAX_DISPLAYED_DETECTIONS)\n\n        lastDetections = filtered\n        drawDetections(filtered, videoEl.videoWidth, videoEl.videoHeight)\n\n        const delta = nowMs - lastFrameMs\n        if (delta > 0) {\n          setFpsStatus(String(Math.round(1000 / delta)))\n        }\n        lastFrameMs = nowMs\n      }).catch(() => {\n        setStreamStatus('Detection loop hit an error')\n      }).finally(() => {\n        busy = false\n      })\n    }\n\n    videoEl.addEventListener('loadeddata', () => {\n      videoReady = true\n      revealStage()\n      if (!currentStreamStatus.includes('error')) {\n        setStreamStatus('Stream active')\n      }\n    })\n\n    videoEl.addEventListener('playing', () => {\n      videoReady = true\n      revealStage()\n      if (!currentStreamStatus.includes('error')) {\n        setStreamStatus('Stream active')\n      }\n    })\n\n    async function initializeTrafficProject() {\n      if (projectInitializing || projectReady) return\n\n      cleanupComplete = false\n\n      projectInitializing = true\n      if (loadProjectBtn) {\n        loadProjectBtn.disabled = true\n        loadProjectBtn.textContent = 'Loading...'\n      }\n\n      setModelStatus('Loading model...')\n      setStreamStatus('Connecting stream...')\n      setBackendStatus('Selecting...')\n      setFpsStatus('0')\n\n      try {\n        await ensureLibraries()\n\n        HlsLib = window.Hls\n        tfLib = window.tf\n        cocoSsdLib = window.cocoSsd\n\n        if (!HlsLib || !tfLib || !cocoSsdLib) {\n          throw new Error('Required libraries failed to initialize')\n        }\n\n        await Promise.all([setupStream(), setupModel()])\n\n        if (!rafId) {\n          rafId = requestAnimationFrame(tick)\n        }\n\n        projectReady = true\n        if (actionsEl) {\n          actionsEl.classList.add('traffic-hidden')\n        }\n      } catch (error) {\n        setStreamStatus(`Init error: ${error?.message || 'unknown error'}`)\n        if (!model) setModelStatus('Model failed to load')\n        if (loadProjectBtn) {\n          loadProjectBtn.disabled = false\n          loadProjectBtn.textContent = 'Load Live Feed'\n        }\n      } finally {\n        projectInitializing = false\n      }\n    }\n\n    if (loadProjectBtn) {\n      loadProjectBtn.addEventListener('click', initializeTrafficProject)\n    }\n\n    if (fullscreenBtnEl) {\n      fullscreenBtnEl.addEventListener('click', toggleStageFullscreen)\n    }\n\n    document.addEventListener('fullscreenchange', updateFullscreenButtonLabel)\n\n    window.addEventListener('pagehide', cleanupTrafficProject)\n    window.addEventListener('beforeunload', cleanupTrafficProject)\n    }\n  </script>\n</body>\n</html>"}}