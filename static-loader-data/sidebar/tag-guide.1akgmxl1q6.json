{"0":null,"0-2":{"rawHtml":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n    <title>Tag Guide</title>\n    <link rel=\"canonical\" href=\"https://codingatmyjob.github.io/sidebar/tag-guide.html\">\n    <link rel=\"stylesheet\" href=\"../style.css\">\n    <style>\n        .tag-guide-intro {\n            margin: 0 0 24px 0;\n            padding: 18px 20px;\n            border: 1px solid var(--border);\n            border-radius: 12px;\n            background: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n        }\n        .tag-guide-intro p:last-child {\n            margin-bottom: 0;\n        }\n        .tag-guide-grid {\n            display: grid;\n            grid-template-columns: repeat(2, minmax(0, 1fr));\n            gap: 14px;\n            margin: 16px 0 24px 0;\n        }\n        .tag-guide-card {\n            border: 1px solid var(--border);\n            border-radius: 12px;\n            padding: 10px 14px;\n            background: rgba(255,255,255,0.025);\n            box-shadow: 0 8px 24px rgba(0,0,0,0.12);\n        }\n        .article-container article .tag-guide-card h3 {\n            margin-top: 0;\n            margin-bottom: 4px;\n        }\n        .tag-guide-chip-row {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 8px;\n            margin: 6px 0 8px 0;\n        }\n        .article-container article .tag-guide-card p {\n            margin: 0;\n        }\n        .tag-guide-example {\n            border: 1px solid var(--border);\n            border-radius: 12px;\n            padding: 12px 16px;\n            margin: 12px 0;\n            background: rgba(255,255,255,0.02);\n        }\n        .tag-guide-example strong {\n            display: block;\n            margin-bottom: 8px;\n        }\n        .tag-guide-rules {\n            margin-top: 10px;\n            padding: 12px 16px;\n            border-left: 4px solid var(--accent);\n            background: rgba(255,255,255,0.03);\n            border-radius: 10px;\n        }\n        [data-theme=\"light\"] .tag-guide-intro,\n        [data-theme=\"light\"] .tag-guide-card,\n        [data-theme=\"light\"] .tag-guide-example {\n            background: rgba(0,0,0,0.025);\n            box-shadow: 0 8px 20px rgba(0,0,0,0.05);\n        }\n        [data-theme=\"light\"] .tag-guide-rules {\n            background: rgba(0,0,0,0.03);\n        }\n        @media (max-width: 700px) {\n            .tag-guide-grid {\n                grid-template-columns: 1fr;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div id=\"binary-bg\" aria-hidden=\"true\"></div>\n\n    <main class=\"article-container\">\n        <h1>Tag Guide</h1>\n\n        <article>\n            <h2>How Tags Work</h2>\n            <div class=\"tag-guide-intro\">\n                <p>\n                    Every article gets <strong>one content-type tag</strong> and then a few <strong>topic tags</strong>. \n                    The first tag tells you the format. The rest tell you the subject. <strong>Notes</strong> is the default for informative posts \n                    that are not a review or project.\n                </p>\n            </div>\n\n            <h2>Content Type Tags</h2>\n            <div class=\"tag-guide-grid\">\n                <div class=\"tag-guide-card\">\n                    <h3>Build / Show</h3>\n                    <div class=\"tag-guide-chip-row\">\n                        <span class=\"tag\">Project</span>\n                        <span class=\"tag\">Demo</span>\n                    </div>\n                    <p><strong>Project</strong> is for something I built or engineered. <strong>Demo</strong> is for a prototype, example, or interactive showcase.</p>\n                </div>\n                <div class=\"tag-guide-card\">\n                    <h3>Explain / Teach</h3>\n                    <div class=\"tag-guide-chip-row\">\n                        <span class=\"tag\">Notes</span>\n                        <span class=\"tag\">Review</span>\n                    </div>\n                    <p><strong>Notes</strong> covers documentation-style or explanatory posts. <strong>Review</strong> is for an opinionated take after using something.</p>\n                </div>\n                <div class=\"tag-guide-card\">\n                    <h3>Challenge / Exam</h3>\n                    <div class=\"tag-guide-chip-row\">\n                        <span class=\"tag\">Writeup</span>\n                        <span class=\"tag\">Cert</span>\n                    </div>\n                    <p><strong>Writeup</strong> is reserved for HTB, CTF, and challenge walkthroughs. <strong>Cert</strong> is for certification-focused posts and exam experiences.</p>\n                </div>\n                <div class=\"tag-guide-card\">\n                    <h3>Lookup / Utility</h3>\n                    <div class=\"tag-guide-chip-row\">\n                        <span class=\"tag\">Reference</span>\n                    </div>\n                    <p><strong>Reference</strong> is for cheatsheets, lookup pages, and content meant to be revisited quickly.</p>\n                </div>\n            </div>\n\n            <h2>Topic Tags</h2>\n            <p>\n                Topic tags are the technologies, platforms, or domains attached to the post. Common examples include <strong>Python</strong>, <strong>Maps</strong>, <strong>Security</strong>, <strong>HTB</strong>, and <strong>API</strong>.\n            </p>\n\n            <h2>What It Looks Like</h2>\n            <div class=\"tag-guide-example\">\n                <strong>Creating a Pokemon Stock Bot</strong>\n                <div class=\"tag-guide-chip-row\">\n                    <span class=\"tag\">Project</span>\n                    <span class=\"tag\">Python</span>\n                    <span class=\"tag\">Discord</span>\n                    <span class=\"tag\">Automation</span>\n                    <span class=\"tag\">API</span>\n                </div>\n            </div>\n            <div class=\"tag-guide-example\">\n                <strong>Typeahead Demo</strong>\n                <div class=\"tag-guide-chip-row\">\n                    <span class=\"tag\">Demo</span>\n                    <span class=\"tag\">JavaScript</span>\n                    <span class=\"tag\">WebApp</span>\n                </div>\n            </div>\n            <div class=\"tag-guide-example\">\n                <strong>HTB Artificial Writeup</strong>\n                <div class=\"tag-guide-chip-row\">\n                    <span class=\"tag\">Writeup</span>\n                    <span class=\"tag\">HTB</span>\n                    <span class=\"tag\">Machine</span>\n                </div>\n            </div>\n            <div class=\"tag-guide-example\">\n                <strong>Passing OCI Foundations Associate</strong>\n                <div class=\"tag-guide-chip-row\">\n                    <span class=\"tag\">Cert</span>\n                    <span class=\"tag\">Cloud</span>\n                </div>\n            </div>\n        </article>\n    </main>\n</body>\n</html>"}}