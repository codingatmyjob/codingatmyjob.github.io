{"0":null,"0-1":{"rawHtml":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n    <title>NOAA Tides LLM Chatbot Demo</title>\n    <link rel=\"stylesheet\" href=\"../style.css\">\n    <style>\n        .demo-section {\n            margin: 1.5rem 0;\n            padding: 1.5rem;\n            background: rgba(128,128,128,0.12);\n            border-radius: 4px;\n        }\n        [data-theme=\"light\"] .demo-section {\n            background: rgba(0,0,0,0.08);\n        }\n        .chat-window {\n            display: flex;\n            flex-direction: column;\n            gap: 0.75rem;\n            max-height: 420px;\n            overflow-y: auto;\n            padding: 0.5rem 0;\n            margin-bottom: 1rem;\n        }\n        .chat-msg {\n            display: flex;\n            flex-direction: column;\n            max-width: 85%;\n        }\n        .chat-msg.user { align-self: flex-end; align-items: flex-end; }\n        .chat-msg.assistant { align-self: flex-start; align-items: flex-start; }\n        .chat-bubble {\n            padding: 0.6rem 0.9rem;\n            border-radius: 4px;\n            font-size: 0.92rem;\n            line-height: 1.5;\n            white-space: pre-wrap;\n            word-break: break-word;\n        }\n        .chat-msg.user .chat-bubble {\n            background: var(--accent);\n            color: var(--bg-primary);\n        }\n        .chat-msg.assistant .chat-bubble {\n            background: var(--bg-secondary);\n            border: 1px solid var(--border);\n            color: var(--text-primary);\n        }\n        .chat-input-row {\n            display: flex;\n            gap: 0.5rem;\n        }\n        .chat-input {\n            flex: 1;\n            padding: 9px 13px;\n            font-size: 0.95rem;\n            border: 1px solid var(--border);\n            border-radius: 3px;\n            background: var(--bg-secondary);\n            color: var(--text-primary);\n            font-family: inherit;\n            box-sizing: border-box;\n            transition: border-color 0.2s;\n        }\n        .chat-input:focus {\n            outline: none;\n            border-color: var(--accent);\n        }\n        .chat-input::placeholder { opacity: 0.4; }\n        .chat-send {\n            padding: 0;\n            width: 36px;\n            height: 36px;\n            flex-shrink: 0;\n            align-self: center;\n            margin: 2px;\n            background: var(--accent);\n            color: var(--bg-primary);\n            border: none;\n            border-radius: 3px;\n            cursor: pointer;\n            transition: opacity 0.2s, transform 0.15s, filter 0.15s;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n        .chat-send:hover:not(:disabled) {\n            filter: brightness(1.1);\n            transform: translateY(-2px);\n        }\n        .chat-send:active:not(:disabled) {\n            transform: scale(0.98);\n        }\n        .chat-send:disabled { opacity: 0.4; cursor: not-allowed; }\n        .chat-status {\n            font-size: 0.8rem;\n            opacity: 0.5;\n            min-height: 1.2em;\n            margin-bottom: 0.5rem;\n        }\n        .typing-indicator::after {\n            content: '▌';\n            animation: blink 0.7s steps(1) infinite;\n        }\n        @keyframes blink { 50% { opacity: 0; } }\n        .suggested-prompts {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 0.4rem;\n            margin-bottom: 1rem;\n        }\n        .suggested-prompt {\n            padding: 4px 10px;\n            font-size: 0.8rem;\n            border: 1px solid var(--border);\n            border-radius: 3px;\n            background: transparent;\n            color: var(--text-primary);\n            font-family: inherit;\n            cursor: pointer;\n            opacity: 0.7;\n            transition: opacity 0.2s, border-color 0.2s;\n        }\n        .suggested-prompt:hover { opacity: 1; border-color: var(--accent); }\n        .rate-limit-note {\n            font-size: 0.78rem;\n            opacity: 0.45;\n            margin-top: 0.75rem;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"binary-bg\" aria-hidden=\"true\"></div>\n    <main class=\"article-container\">\n        <article>\n            <h1>NOAA Tides LLM Chatbot Demo</h1>\n            <div class=\"meta\">\n                <time datetime=\"DRAFT\">DRAFT</time>\n            </div>\n            <div class=\"tags\">\n                <span class=\"tag\">Demo</span><span class=\"tag\">LLM</span><span class=\"tag\">Node.js</span><span class=\"tag\">API</span>\n            </div>\n            <h2>Overview</h2>\n            <p>This is a simple LLM enabled chatbot demo that connects a Groq-hosted LLM to the NOAA tide station data via API. Ask about tide predictions or current water levels at any U.S. coastal station.\n            The goal was to build an interactive frontend similar to the <a href=\"#/articles/typeahead-demo\">Typeahead demo</a>, but have an actual backend that handles LLM tool calling.</p>\n\n            <div class=\"demo-section\">\n                <div class=\"chat-window\" id=\"chat-window\">\n                    <div class=\"chat-msg assistant\">\n                        <div class=\"chat-bubble\">Hey! Ask me about tides anywhere along the U.S. coast. I can look up predictions, high/low times, and current water levels using real NOAA data.</div>\n                    </div>\n                </div>\n                <div class=\"suggested-prompts\" id=\"suggested-prompts\">\n                    <button class=\"suggested-prompt\">What are the tides in San Francisco today?</button>\n                    <button class=\"suggested-prompt\">High and low tides in Miami this weekend</button>\n                    <button class=\"suggested-prompt\">Current water level at The Battery, NY</button>\n                    <button class=\"suggested-prompt\">Find tide stations near Seattle</button>\n                </div>\n                <div class=\"chat-status\" id=\"chat-status\"></div>\n                <div class=\"chat-input-row\">\n                    <input class=\"chat-input\" id=\"chat-input\" type=\"text\" placeholder=\"Ask about tides anywhere on the U.S. coast...\" maxlength=\"500\" />\n                    <button class=\"chat-send\" id=\"chat-send\" aria-label=\"Send\">\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M2.01 21L23 12 2.01 3 2 10l15 2-15 2z\"/></svg>\n                    </button>\n                </div>\n                <p class=\"rate-limit-note\">Rate limited to 10 requests per hour per IP. Powered by Groq + NOAA CO-OPS API.</p>\n            </div>\n\n            <h2>The Token Problem</h2>\n            <p>I can't expose an API key (like Copilot) in a public demo for obvious reasons. The solution was a free-tier LLM to demo with, and I ended up choosing llama3-70b-8192 on Groq. \n                The model has plenty of free calls, and I easily configured simple controls and abuse prevention; IP rate limiting (10/hour/IP), Request size limit \n                (inputs over 500 characters rejected), and a CORS whitelist for only this domain.\n            </p>\n\n            <h2>Architecture</h2>\n            <p>GitHub Pages hosts a static frontend with JS React and Vite. It can't execute server-side code, so a separate Node.js backend on Fly.io handles the LLM calls, enforces rate limits, and keeps secrets hidden.</p>\n            <p>When the user sends a message, Groq decides which tool to call but can't reach NOAA directly. It returns a specific instruction to the backend indicating the tool to use. \n                The backend then fetches the data and sends it back to Groq to generate the final response which is streamed back to the user on the frontend.</p>\n                <pre><code class=\"language-text\">  Browser (GitHub Pages)\n          ↓ POST /chat\n  Fly.io - Node.js backend\n          ↓ message\n  Groq (LLaMA 3)\n          ↓ \"call get_tides(station, date)\"\n  Fly.io - Node.js backend\n          ↓ fetch\n  NOAA API\n          ↓ data\n  Fly.io - Node.js backend\n          ↓ data + original message\n  Groq (LLaMA 3)\n          ↓ streamed response\n  Browser (GitHub Pages)</code></pre>\n\n        <h2>LLM Powered Chatbot vs MCP</h2>\n        <p>Model Context Protocol (MCP) servers dynamically expose tools, resources, and prompts at runtime, so a client can discover what's available without anything being hardcoded.\n            Traditional LLM tool-calling requires every tool to be defined upfront and shipped with the application. MCP also operates over a standardized protocol,\n            meaning any compatible client can connect to any MCP server with no custom integration required. MCP clearly has an edge in flexibility, but \n            the runtime loops of MCP and traditional LLM chatbots look identical, and both approaches share more than they don't.</p>\n\n        <p><strong>They are <i>incredibly</i> similar, in fact, BOTH:</strong></p>\n        <ul>\n            <li>Rely on the LLM to determine which tools to call</li>\n            <li>Require specific tool definitions (name, parameters, description)</li>\n            <li>Follow the same pattern: LLM → pick tool → backend processes task → return result to LLM</li>\n            <li>Can use the same tool types (fetch, database queries, etc.)</li>\n            <li>Are only as good as the LLM doing the processing</li>\n        </ul>\n        <p>My biggest complaint with MCP is that it doesn't really feel new. It's an old dog with new tricks. The crucial\n            difference between the two lies in the additional resources and reasoning capabilities MCP clients can leverage at run time. \n            With MCP, models can create incredibly unique workflows on the fly, chaining tool calls together to achieve complex results. \n            With a traditional LLM chatbot, the tools and workflows are more or less fixed. </p>\n        </article>\n    </main>\n\n    <script>\n        const API_URL = 'https://noaa-tides-api.fly.dev/chat'\n        const chatWindow = document.getElementById('chat-window')\n        const chatInput = document.getElementById('chat-input')\n        const chatSend = document.getElementById('chat-send')\n        const chatStatus = document.getElementById('chat-status')\n        const suggestedPrompts = document.getElementById('suggested-prompts')\n\n        const messages = []\n\n        function appendMessage(role, content) {\n            const msg = document.createElement('div')\n            msg.className = `chat-msg ${role}`\n            const bubble = document.createElement('div')\n            bubble.className = 'chat-bubble'\n            bubble.textContent = content\n            msg.appendChild(bubble)\n            chatWindow.appendChild(msg)\n            chatWindow.scrollTop = chatWindow.scrollHeight\n            return bubble\n        }\n\n        async function sendMessage(text) {\n            if (!text.trim()) return\n            chatSend.disabled = true\n            chatInput.disabled = true\n            suggestedPrompts.style.display = 'none'\n\n            appendMessage('user', text)\n            messages.push({ role: 'user', content: text })\n            chatInput.value = ''\n\n            const bubble = appendMessage('assistant', '')\n            bubble.classList.add('typing-indicator')\n            chatStatus.textContent = 'Thinking...'\n\n            try {\n                const res = await fetch(API_URL, {\n                    method: 'POST',\n                    headers: { 'Content-Type': 'application/json' },\n                    body: JSON.stringify({ messages }),\n                })\n\n                if (!res.ok) {\n                    const err = await res.json()\n                    bubble.classList.remove('typing-indicator')\n                    bubble.textContent = err.error || 'Something went wrong.'\n                    chatStatus.textContent = ''\n                    return\n                }\n\n                const reader = res.body.getReader()\n                const decoder = new TextDecoder()\n                let assistantText = ''\n                chatStatus.textContent = 'Responding...'\n\n                while (true) {\n                    const { done, value } = await reader.read()\n                    if (done) break\n                    const chunk = decoder.decode(value, { stream: true })\n                    for (const line of chunk.split('\\n')) {\n                        if (!line.startsWith('data: ')) continue\n                        const payload = line.slice(6).trim()\n                        if (payload === '[DONE]') break\n                        try {\n                            const { text, error } = JSON.parse(payload)\n                            if (error) { assistantText = error; break }\n                            if (text) assistantText += text\n                        } catch {}\n                        bubble.classList.remove('typing-indicator')\n                        bubble.textContent = assistantText\n                        chatWindow.scrollTop = chatWindow.scrollHeight\n                    }\n                }\n\n                messages.push({ role: 'assistant', content: assistantText })\n                chatStatus.textContent = ''\n            } catch (err) {\n                bubble.classList.remove('typing-indicator')\n                bubble.textContent = 'Could not reach the server. Try again later.'\n                chatStatus.textContent = ''\n            } finally {\n                chatSend.disabled = false\n                chatInput.disabled = false\n                chatInput.focus()\n            }\n        }\n\n        chatSend.addEventListener('click', () => sendMessage(chatInput.value))\n        chatInput.addEventListener('keydown', e => { if (e.key === 'Enter') sendMessage(chatInput.value) })\n        suggestedPrompts.querySelectorAll('.suggested-prompt').forEach(btn => {\n            btn.addEventListener('click', () => sendMessage(btn.textContent))\n        })\n    </script>\n</body>\n</html>\n"}}